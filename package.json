{
  "name": "forge-protocol",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "anchor-test": "anchor test",
    "web-dev": "bun --env-file=../../.env.local --cwd apps/web dev",
    "web-build": "bun --cwd apps/web build",
    "test:backend": "vitest run --config vitest.config.ts",
    "test:backend:watch": "vitest --config vitest.config.ts",
    "test:backend:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "chai": "^4.3.4",
    "mkdirp": "^3.0.1",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3",
    "uuid": "^14.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.9",
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0"
  }
}